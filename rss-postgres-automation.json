    {
      "parameters": {
        "command": "cat <<EOF > /tmp/get_favourites_success.py\nimport psycopg2\nimport json\nimport sys\n\ntry:\n    conn = psycopg2.connect(\n        host=\"postgres-vector\",\n        database=\"freshrss_db\",\n        user=\"postgres\",\n        password=\"mi_contraseña\"\n    )\n    cur = conn.cursor()\n    \n    # CONSULTA CORREGIDA: Usamos 1 en lugar de true\n    cur.execute(\"\"\"\n        SELECT e.id, e.title, e.link, array_agg(t.name) as tags\n        FROM \"Paul_entry\" e\n        LEFT JOIN \"Paul_entrytag\" et ON e.id = et.id_entry\n        LEFT JOIN \"Paul_tag\" t ON et.id_tag = t.id\n        WHERE e.is_favorite = 1\n        GROUP BY e.id, e.title, e.link;\n    \"\"\")\n    \n    articles = cur.fetchall()\n    \n    items_list = []\n    for article in articles:\n        items_list.append({\n            'id': article[0],\n            'title': article[1],\n            'url': article[2],\n            'tags': article[3] if article[3] else []\n        })\n\n    output = {'status': 'success', 'count': len(items_list), 'items': items_list}\n    print(json.dumps(output))\n\n    cur.close()\n    conn.close()\n\nexcept Exception as e:\n    output = {'status': 'error', 'message': str(e)}\n    print(json.dumps(output), file=sys.stderr)\n    sys.exit(1)\nEOF\n\n/opt/py-env/bin/python3 /tmp/get_favourites_success.py"
